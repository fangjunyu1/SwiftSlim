        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ξεκινήστε από τα βασικά, μάθετε σταδιακά τις συνηθισμένες χρήσεις του SwiftUI και διαμορφώστε μια ξεκάθαρη λογική ανάπτυξης."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
